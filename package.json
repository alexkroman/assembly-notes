{
  "name": "assembly-notes",
  "productName": "Assembly Notes",
  "description": "Assembly Notes",
  "keywords": [],
  "main": "./src/main/main.js",
  "version": "1.0.18",
  "author": "Alex Kroman <alex@alexkroman.com>",
  "scripts": {
    "start": "electron .",
    "build": "npm run build-icons && electron-builder --mac --win --linux",
    "build:mac": "npm run build-icons && electron-builder --mac",
    "build:mac:notarized": "npm run build-icons && APPLE_ID=$APPLE_ID APPLE_ID_PASSWORD=$APPLE_ID_PASSWORD APPLE_TEAM_ID=$APPLE_TEAM_ID CSC_LINK=$CSC_LINK CSC_KEY_PASSWORD=$CSC_KEY_PASSWORD electron-builder --mac --publish=never",
    "build:win": "npm run build-icons && electron-builder --win",
    "build:linux": "npm run build-icons && electron-builder --linux",
    "build-icons": "electron-icon-builder --input=./icon.png --output=./build",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build",
    "pack": "electron-builder --dir",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "release:patch": "npm version patch && git push origin main --tags",
    "release:minor": "npm version minor && git push origin main --tags",
    "release:major": "npm version major && git push origin main --tags"
  },
  "dependencies": {
    "@slack/web-api": "^7.9.3",
    "assemblyai": "^4.14.0",
    "electron-audio-loopback": "^1.0.5",
    "electron-log": "^5.4.1",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.6.2",
    "npm-check-updates": "^18.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/jest": "^30.0.0",
    "electron": "37.2.4",
    "electron-builder": "^26.0.12",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "jest-environment-node": "^30.0.5",
    "prettier": "^3.6.2"
  },
  "build": {
    "appId": "com.alexkroman.assembly-notes",
    "productName": "Assembly Notes",
    "forceCodeSigning": false,
    "publish": {
      "provider": "github"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/electron-audio-loopback/**/*",
      "node_modules/**/*.node"
    ],
    "extraMetadata": {
      "main": "src/main/main.js"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "icon": "build/icons/mac/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "win": {
      "target": "nsis",
      "icon": "build/icons/win/icon.ico",
      "forceCodeSigning": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/png",
      "category": "Office",
      "synopsis": "Real-time transcription and meeting notes",
      "description": "Assembly Notes provides real-time transcription of microphone and system audio with AI-generated meeting summaries posted to Slack."
    }
  }
}
